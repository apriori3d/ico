{
    // ───────────────────────────────────────────
    // PYTHON ENVIRONMENT
    // ───────────────────────────────────────────
    "python.envFile": "${workspaceFolder}/.env",
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
    "python.languageServer": "Pylance",
    // ───────────────────────────────────────────
    // PYTHON ANALYSIS / AUTOCOMPLETE
    // ───────────────────────────────────────────
    "python.analysis.indexing": true,
    "python.analysis.autoImportCompletions": true,
    "python.analysis.completeFunctionParens": true,
    // Extra import paths (deps)
    "python.analysis.extraPaths": [
        "${workspaceFolder}/src",
    ],
    // ───────────────────────────────────────────
    // MYpy — Microsoft Extension
    // ───────────────────────────────────────────
    "mypy-type-checker.runUsingActiveInterpreter": true,
    "mypy-type-checker.preferDaemon": true,
    "mypy-type-checker.importStrategy": "fromWorkspace",
    "mypy-type-checker.args": [
        "--strict"
    ],
    // ОТКЛЮЧАЕМ старый Matan Gober mypy plugin
    //"python.linting.mypyEnabled": false,
    // Disable legacy mypy from python extension
    "python.linting.mypyEnabled": false,
    "python.linting.enabled": false,
    // ───────────────────────────────────────────
    // RUFF
    // ───────────────────────────────────────────
    "editor.defaultFormatter": "charliermarsh.ruff",
    "ruff.enable": true,
    "ruff.enableExperimental": true,
    "editor.codeActionsOnSave": {
        "source.fixAll": "explicit"
    },
    "editor.formatOnSave": true,
    // ───────────────────────────────────────────
    // EDITOR BEHAVIOR
    // ───────────────────────────────────────────
    "editor.insertSpaces": true,
    "editor.detectIndentation": false,
    "editor.tabSize": 4,
    "editor.quickSuggestions": {
        "other": true,
        "comments": false,
        "strings": false
    },
    "editor.parameterHints.enabled": true,
    // JSON formatting separate
    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    }
}