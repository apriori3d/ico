    "def _estimator_fn(self, item: I) -> O: ...\n",
    "\n",
    "        if self.mode == \"fit\":\n",
    "            if hasattr(self.estimator, \"fit\"):\n",
    "                self.estimator.fit(item.x, item.y) # type: ignore\n",
    "            elif hasattr(self.estimator, \"fit_transform\"):\n",
    "                item = self.estimator.fit_transform(item.x, self.columns) # type: ignore\n",
    "            return item # type: ignore\n",
    "\n",
    "        # Prediction mode\n",
    "        if hasattr(self.estimator, \"predict\"):\n",
    "            predictions = self.estimator.predict(item.x) # type: ignore\n",
    "            return XYData(x=item.x, y=predictions) # type: ignore\n",
    "\n",
    "        if hasattr(self.estimator, \"transform\"):\n",
    "            transformed = self.estimator.transform(item.x) # type: ignore\n",
    "            return XYData(x=transformed, y=item.y) # type: ignore\n"
   ]
  },
