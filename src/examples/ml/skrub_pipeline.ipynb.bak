    "from typing_extensions import get_args\n",
    "\n",
    "from skrub._to_str import ToStr\n",
    "\n",
    "from ico.core.signature_utils import get_generic_args # pyright: ignore[reportMissingTypeStubs]\n",
    "\n",
    "\n",
    "class TestTransformer(SKBaseTransformer[int, O], Generic[O]):\n",
    "\n",
    "    def _fit_transform(self, input: XSeries) -> SKResultTypes:\n",
    "        return self.estimator.fit_transform(input.X)  # type: ignore\n",
    "\n",
    "    def _transform(self, input: XSeries) -> SKResultTypes:\n",
    "        return self.estimator.transform(input.X)  # type: ignore\n",
    "\n",
    "    def _wrap_result(self, input: I, x1: SKResultTypes) -> O:\n",
    "        raise NotImplementedError(\"This is a test transformer and should not be used in production.\")\n",
    "\n",
    "\n",
    "\n",
    "t = TestTransformer[float](ToStr())\n",
    "tc = type(t)\n",
    "instance_class = getattr(t, \"__orig_class__\", None)\n",
    "instance_args = get_args(instance_class)\n",
    "\n",
    "print(f\"{instance_class=}\")\n",
    "print(f\"{instance_args=}\")\n",
