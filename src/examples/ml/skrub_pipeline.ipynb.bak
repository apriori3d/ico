    "\n",
    "\n",
    "class ApplyToColumns(SKBaseOperator[pd.DataFrame, pd.DataFrame]):\n",
    "    cols: Callable[[], list[str]]\n",
    "\n",
    "    def __init__(\n",
    "        self,\n",
    "        transformer: sklearn.base.BaseEstimator,\n",
    "        cols: Callable[[], list[str]] = selectors.all(), # type: ignore\n",
    "        *,\n",
    "        name: str | None = None,\n",
    "    ) -> None:\n",
    "        super().__init__(transformer, name=name)\n",
    "        self.cols = cols\n",
    "\n",
    "    def _estimator_fn(self, input: pd.DataFrame) -> pd.DataFrame:\n",
    "\n",
    "\n",
    "# class PandaXColumnExtractor(IcoOperator[XYData, pd.Series]):\n",
    "\n",
    "#     column: str\n",
    "\n",
    "#     def __init__(\n",
