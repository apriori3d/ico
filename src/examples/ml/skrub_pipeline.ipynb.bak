       "\u001b[1m \u001b[0m\u001b[1mFlow                           \u001b[0m\u001b[1m \u001b[0m\u001b[1m \u001b[0m\u001b[1mSignature\u001b[0m\u001b[1m \u001b[0m\u001b[1m \u001b[0m\u001b[1mName\u001b[0m\u001b[1m \u001b[0m\n",
       " \u001b[38;2;0;82;204mXSeriesTransformer(\u001b[0m\u001b[38;2;0;82;204m)\u001b[0m             \u001b[2;36mAny\u001b[0m\u001b[38;5;249m → \u001b[0m\u001b[2;36mAny\u001b[0m  \u001b[38;2;78;177;105m    \u001b[0m \n",
       " \u001b[38;2;0;82;204mXSeriesToDataFrameTransformer(\u001b[0m\u001b[38;2;0;82;204m)\u001b[0m  \u001b[2;36mAny\u001b[0m\u001b[38;5;249m → \u001b[0m\u001b[2;36mAny\u001b[0m  \u001b[38;2;78;177;105m    \u001b[0m \n",
       " \u001b[38;2;0;82;204mXDataFrameTransformer(\u001b[0m\u001b[38;2;0;82;204m)\u001b[0m          \u001b[2;36mAny\u001b[0m\u001b[38;5;249m → \u001b[0m\u001b[2;36mAny\u001b[0m  \u001b[38;2;78;177;105m    \u001b[0m \n"
      ]
     },
