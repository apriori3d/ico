   "source": [
    "\n",
    "from types import GenericAlias\n",
    "from typing import OrderedDict, get_args, get_origin\n",
    "\n",
    "from networkx import ancestors\n",
    "\n",
    "import ico\n",
    "from ico.core.context_operator import C, IcoContextOperator\n",
    "from ico.core.node import IcoNode\n",
    "\n",
    "ico_mro: list[type] = [c for c in tc.__mro__ if issubclass(c, (IcoOperator, IcoContextOperator))]\n",
    "\n",
    "ico_mro_generics: list[GenericAlias] = [\n",
    "    orig\n",
    "    for c in ico_mro\n",
    "    for orig in getattr(c, \"__orig_bases__\", ())\n",
    "    if issubclass(get_origin(orig) or object, (IcoOperator, IcoContextOperator))\n",
    "    ]\n",
    "\n",
    "if instance_class:= getattr(t, \"__orig_class__\", None):\n",
    "    ico_mro_generics.insert(0, instance_class)\n",
    "\n",
    "if len(ico_mro_generics) == 0:\n",
    "    raise ValueError(\"No generic base class found in MRO\")\n",
    "\n",
    "base_class = get_origin(ico_mro_generics[-1])\n",
    "if base_class is IcoOperator:\n",
    "    resolving_args = OrderedDict(((I, None), (O, None)))\n",
    "elif base_class is IcoContextOperator:\n",
    "    resolving_args = OrderedDict(((I, None), (C, None), (O, None)))\n",
    "else:\n",
    "    raise ValueError(\"Unexpected base class, expected IcoOperator or IcoContextOperator\")\n",
    "\n",
    "for bc in reversed(ico_mro_generics):\n",
    "    print(f\"bc={bc}\")\n",
    "\n",
    "    args = get_args(bc)\n",
    "    defined_args = [a for a in args if not isinstance(a, TypeVar)]\n",
    "    updating_args = {a: c for a, c in resolving_args.items() if c is None and a not in args}\n",
    "    print(f\"{args=}, {defined_args=}, {updating_args=}\")\n",
    "\n",
    "    if len(defined_args) != len(updating_args):\n",
    "        raise ValueError(\"Unresolved\")\n",
    "\n",
    "    resolved_args = {\n",
    "        arg: defined_args[i] for i, arg in enumerate(updating_args.keys())\n",
    "    }\n",
    "    print(f\"resolved_args={resolved_args}\")\n",
    "\n",
    "    resolving_args.update(resolved_args)\n",
    "\n",
    "\n",
    "print(f\"{resolving_args=}\")\n",
    "\n",
    "\n"
   ]
  },
